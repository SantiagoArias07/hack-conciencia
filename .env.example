# Recomendaciones por LLM (función serverless /api/recommendations)
# Consigue una API key GRATIS en https://console.groq.com/keys
GROQ_API_KEY=

# Opcional — modelo de Groq (default: llama-3.1-8b-instant, ~5x más cupo diario).
# Para mayor calidad y si hay presupuesto: llama-3.3-70b-versatile
GROQ_MODEL=llama-3.1-8b-instant

# Opcional — endpoint del backend ML de Railway (lo usa /api/predict como proxy)
# BACKEND_PREDICT_URL=https://hackatonagentes-conciencia-production.up.railway.app/predict
